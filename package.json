{
  "name": "your-assistant",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "author": {
    "name": "Your Assistant",
    "email": "noreply@example.com"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "serve": "vue-cli-service serve",
    "serve:https": "VUE_APP_HTTPS=true vue-cli-service serve",
    "serve:http": "VUE_APP_HTTPS=false vue-cli-service serve",
    "generate:certs": "node scripts/generate-certs.js",
    "build": "vue-cli-service build",
    "build:preview": "NODE_ENV=production npm run build",
    "preview": "npx serve dist -l 3000",
    "build:serve": "npm run build:preview && npm run preview",
    "test:deployment": "npm run build:preview && node scripts/test-deployment.js",
    "lint": "eslint src --ext .js,.vue --fix",
    "lint:check": "eslint src --ext .js,.vue",
    "format": "prettier --write src/**/*.{js,vue}",
    "format:check": "prettier --check src/**/*.{js,vue}",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "electron:dev": "concurrently -k \"npm run serve\" \"wait-on http://localhost:8080 && NODE_ENV=development electron .\"",
    "electron:dev:https": "concurrently -k \"npm run serve:https\" \"wait-on https-get://localhost:8080 --timeout 30000 && VUE_APP_HTTPS=true NODE_ENV=development electron .\"",
    "electron:build": "cross-env ELECTRON_BUILD=true vue-cli-service build && electron-builder",
    "electron:build:mac": "cross-env ELECTRON_BUILD=true vue-cli-service build && electron-builder --mac",
    "electron:build:win": "cross-env ELECTRON_BUILD=true vue-cli-service build && electron-builder --win",
    "electron:build:linux": "cross-env ELECTRON_BUILD=true vue-cli-service build && electron-builder --linux",
    "electron:build:linux:ci": "cross-env ELECTRON_BUILD=true vue-cli-service build && cross-env ELECTRON_BUILDER_ALLOW_UNRESOLVED_DEPENDENCIES=true electron-builder --linux",
    "release": "semantic-release"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@deepgram/sdk": "^3.13.0",
    "@google/genai": "^0.3.0",
    "assert-js": "^1.0.0",
    "axios": "^1.6.2",
    "core-js": "^3.8.3",
    "dompurify": "^3.0.6",
    "element-plus": "^2.5.0",
    "markdown-it": "^14.1.1",
    "marked": "^17.0.4",
    "microsoft-cognitiveservices-speech-sdk": "^1.33.1",
    "moment": "^2.29.4",
    "openai": "^6.29.0",
    "pdfjs-dist": "^5.5.207",
    "pinia": "^2.1.0",
    "playwright": "^1.58.2",
    "screenshot-desktop": "^1.15.3",
    "turndown": "^7.2.2",
    "universal-cookie": "^8.0.1",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@google/genai": "^0.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@vue/cli-plugin-babel": "~5.0.8",
    "@vue/cli-plugin-router": "~5.0.8",
    "@vue/cli-service": "~5.0.8",
    "cross-env": "^7.0.3",
    "@vue/compiler-sfc": "^3.4.0",
    "@eslint/js": "^9.0.0",
    "@eslint/eslintrc": "^3.0.0",
    "eslint-plugin-vue": "^9.17.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/vue3-jest": "^29.2.6",
    "concurrently": "^8.2.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.1.0",
    "semantic-release": "^24.2.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.yourassistant.app",
    "productName": "Your Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}