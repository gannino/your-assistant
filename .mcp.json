{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "description": "Live library documentation (Next.js, React, any npm package)"
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "description": "Persistent knowledge graph for cross-session facts"
    }
  },
    "github.com/modelcontextprotocol/servers/tree/main/src/filesystem": {
      "autoApprove": [
        "read_media_file",
        "read_multiple_files",
        "list_directory",
        "list_directory_with_sizes",
        "directory_tree",
        "search_files",
        "get_file_info",
        "list_allowed_directories",
        "read_text_file"
      ],
      "timeout": 60,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/gma/repo/tf-kube-any-compute",
        "/Users/gma/repo/"
      ]
    },
    "kubernetes-mcp-server": {
      "autoApprove": [
        "kubectl_describe",
        "kubectl_get"
      ],
      "disabled": false,
      "timeout": 60,
      "type": "stdio",
      "command": "node",
      "args": [
        "/opt/homebrew/lib/node_modules/mcp-server-kubernetes/dist/index.js"
      ],
      "env": {
        "KUBECONFIG": "/Users/gma/.kube/config"
      }
    },
    "github.com/AgentDeskAI/browser-tools-mcp": {
      "autoApprove": [],
      "disabled": false,
      "timeout": 60,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@agentdeskai/browser-tools-mcp@latest"
      ]
    },
    "github.com/modelcontextprotocol/servers/tree/main/src/sequentialthinking": {
      "autoApprove": [],
      "timeout": 60,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "github.com/executeautomation/mcp-playwright": {
      "autoApprove": [
        "playwright_navigate",
        "playwright_screenshot",
        "playwright_click",
        "playwright_fill",
        "playwright_evaluate",
        "playwright_get_text",
        "playwright_resize"
      ],
      "disabled": false,
      "timeout": 120,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@executeautomation/playwright-mcp-server"
      ]
    },
    "github.com/microsoft/playwright-mcp": {
      "autoApprove": [
        "browser_snapshot",
        "browser_click",
        "browser_type",
        "browser_hover",
        "browser_close",
        "browser_tabs",
        "browser_take_screenshot"
      ],
      "disabled": false,
      "timeout": 30,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "github.com/modelcontextprotocol/servers/tree/main/src/git": {
      "autoApprove": [
        "git_status",
        "git_diff_unstaged",
        "git_diff_staged",
        "git_diff",
        "git_commit",
        "git_add",
        "git_reset",
        "git_log",
        "git_create_branch",
        "git_checkout",
        "git_show",
        "git_branch"
      ],
      "timeout": 60,
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "/Users/gma/repo/tf-kube-any-compute"
      ]
    },
    "github.com/modelcontextprotocol/servers/tree/main/src/memory": {
      "autoApprove": [
        "create_entities",
        "create_relations",
        "add_observations",
        "delete_entities",
        "delete_observations",
        "delete_relations",
        "read_graph",
        "search_nodes",
        "open_nodes"
      ],
      "timeout": 60,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "github.com/modelcontextprotocol/servers/tree/main/src/time": {
      "autoApprove": [
        "get_current_time",
        "convert_time"
      ],
      "disabled": false,
      "timeout": 60,
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-time"
      ]
    }
}
